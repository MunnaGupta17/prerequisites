# Copy this file to .env and fill in your values

# PostgreSQL connection string
# Local:  postgresql://postgres:password@localhost:5432/prerequisites
# Railway/Supabase: they give you this URL directly
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/prerequisites"

# Port for the Express server
PORT=5000

# Frontend URL for CORS (change in production)
FRONTEND_URL="http://localhost:3000"
